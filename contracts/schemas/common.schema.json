{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://semidx.example/contracts/schemas/common.schema.json",
  "title": "Semantic Code Indexing Common Definitions",
  "description": "Shared definitions for retrieval contracts and diagnostics.",
  "$defs": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^1\\.0$",
      "description": "Contract schema version.",
      "examples": ["1.0"]
    },
    "uuid": {
      "type": "string",
      "format": "uuid",
      "description": "RFC 4122 UUID."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp."
    },
    "code": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$",
      "description": "Machine-readable code."
    },
    "codeArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/code"
      },
      "maxItems": 12,
      "uniqueItems": true,
      "default": []
    },
    "boundedString": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "boundedLongString": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "stringArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/boundedString"
      },
      "maxItems": 25,
      "uniqueItems": true,
      "default": []
    },
    "codedItem": {
      "type": "object",
      "required": ["code", "summary"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "$ref": "#/$defs/code"
        },
        "summary": {
          "$ref": "#/$defs/boundedString"
        }
      }
    },
    "codedItemArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/codedItem"
      },
      "maxItems": 12,
      "default": []
    },
    "confidenceLevel": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "autonomyPosture": {
      "type": "string",
      "enum": ["read_safe", "plan_safe", "draft_patch_safe", "autonomy_blocked"]
    },
    "usageSurface": {
      "type": "string",
      "enum": ["library", "mcp", "http", "grpc"]
    },
    "usageOperation": {
      "type": "string",
      "enum": [
        "server_start",
        "create_index",
        "update_index",
        "repo_map",
        "resolve_context",
        "expand_context",
        "fetch_context_detail",
        "impact_analysis",
        "skeletons",
        "cache_eviction"
      ]
    },
    "usageStatus": {
      "type": "string",
      "enum": ["success", "error"]
    },
    "feedbackOutcome": {
      "type": "string",
      "enum": ["helpful", "partially_helpful", "not_helpful", "abandoned"]
    },
    "followupAction": {
      "type": "string",
      "enum": ["planned", "drafted", "patched", "discarded"]
    },
    "retrievalIssueCode": {
      "type": "string",
      "enum": [
        "resolved_target_correct",
        "missing_authority",
        "wrong_scope",
        "too_broad",
        "too_shallow",
        "latency_too_high",
        "confidence_miscalibrated"
      ]
    },
    "stageName": {
      "type": "string",
      "enum": [
        "query_validation",
        "candidate_generation",
        "ranking",
        "context_packet_assembly",
        "raw_code_fetch",
        "result_finalization"
      ]
    },
    "stageOutcome": {
      "type": "string",
      "enum": ["completed", "degraded", "failed", "skipped"]
    },
    "eventStatus": {
      "type": "string",
      "enum": ["started", "completed", "degraded", "failed", "skipped"]
    },
    "rawFetchLevel": {
      "type": "string",
      "enum": ["none", "target_span", "enclosing_unit", "local_neighborhood", "whole_file"]
    },
    "rankBand": {
      "type": "string",
      "enum": ["top_authority", "useful_support", "exploratory", "below_threshold_noise"]
    },
    "unitKind": {
      "type": "string",
      "enum": [
        "namespace",
        "module",
        "class",
        "type",
        "function",
        "method",
        "protocol",
        "interface",
        "section",
        "block",
        "test"
      ]
    },
    "span": {
      "type": "object",
      "required": ["path", "start_line", "end_line"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "$ref": "#/$defs/boundedString"
        },
        "start_line": {
          "type": "integer",
          "minimum": 1
        },
        "end_line": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "traceRef": {
      "type": "object",
      "required": ["trace_id", "request_id"],
      "additionalProperties": false,
      "properties": {
        "trace_id": {
          "$ref": "#/$defs/uuid"
        },
        "request_id": {
          "$ref": "#/$defs/boundedString"
        },
        "task_id": {
          "$ref": "#/$defs/boundedString"
        },
        "session_id": {
          "$ref": "#/$defs/boundedString"
        },
        "actor_id": {
          "$ref": "#/$defs/boundedString"
        }
      }
    },
    "metricMap": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/code"
      },
      "additionalProperties": {
        "type": ["integer", "number"]
      },
      "maxProperties": 12,
      "default": {}
    },
    "rootPathHash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "boundedPayloadValue": {
      "anyOf": [
        {
          "$ref": "#/$defs/boundedString"
        },
        {
          "type": "boolean"
        },
        {
          "type": "integer"
        },
        {
          "type": "number"
        }
      ]
    },
    "boundedPayloadMap": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/code"
      },
      "additionalProperties": {
        "$ref": "#/$defs/boundedPayloadValue"
      },
      "maxProperties": 16,
      "default": {}
    },
    "retrievalPolicySummary": {
      "type": "object",
      "required": ["policy_id", "version"],
      "additionalProperties": false,
      "properties": {
        "policy_id": {
          "$ref": "#/$defs/boundedString"
        },
        "version": {
          "$ref": "#/$defs/boundedString"
        }
      }
    },
    "capabilitySummary": {
      "type": "object",
      "required": [
        "index_languages",
        "selected_languages",
        "parser_modes",
        "coverage_level",
        "fallback_unit_count",
        "selected_unit_count",
        "strong_languages",
        "index_snapshot_id"
      ],
      "additionalProperties": false,
      "properties": {
        "index_languages": {
          "$ref": "#/$defs/stringArray"
        },
        "selected_languages": {
          "$ref": "#/$defs/stringArray"
        },
        "parser_modes": {
          "$ref": "#/$defs/stringArray"
        },
        "coverage_level": {
          "type": "string",
          "enum": ["unknown", "full", "mixed", "fallback_only"]
        },
        "fallback_unit_count": {
          "type": "integer",
          "minimum": 0
        },
        "selected_unit_count": {
          "type": "integer",
          "minimum": 0
        },
        "strong_languages": {
          "$ref": "#/$defs/stringArray"
        },
        "index_snapshot_id": {
          "$ref": "#/$defs/boundedString"
        }
      }
    }
  }
}
